# ============================================================
#  환경변수 예시 — 실제 값은 .env.local 에 넣고 절대 커밋하지 마라 (§0-15, §11, §22)
#  복사: cp .env.example .env.local  (Windows: copy .env.example .env.local)
# ============================================================

# 사이트 기본 URL (canonical / sitemap / RSS 생성에 사용)
SITE_URL="http://localhost:3000"
SITE_NAME="트로트 인포"

# --- 데이터베이스 ---
# 로컬: SQLite (기본). 프로덕션: PostgreSQL 권장.
#   DATABASE_PROVIDER 로 스키마 provider 를 스위치한다(scripts/set-db-provider.mjs).
DATABASE_PROVIDER="sqlite"           # sqlite | postgresql
DATABASE_URL="file:./dev.db"
# 프로덕션 예시:
#   DATABASE_PROVIDER="postgresql"
#   DATABASE_URL="postgresql://user:pass@host:5432/trot?schema=public"

# Docker Compose 용 Postgres 값 (docker-compose.yml)
POSTGRES_USER="trot"
POSTGRES_PASSWORD="change-this-strong-password"
POSTGRES_DB="trot"
# 최초 배포 시 관리자 자동 생성 여부 (docker-entrypoint.sh)
BOOTSTRAP_ADMIN="true"

# --- 관리자 인증 세션 서명 키 (jose HS256). 32바이트 이상 랜덤 문자열 ---
# 생성 예: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
AUTH_SECRET="change-me-to-a-long-random-secret-value"

# 초기 관리자 계정 (seed 시 1회 생성). 실제 운영 전 반드시 변경.
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-this-password"

# --- OpenAI 이미지 생성 API (§11). 없으면 이미지 생성은 건너뛰고 기본 카테고리 이미지 사용 ---
OPENAI_API_KEY=""
OPENAI_IMAGE_MODEL="gpt-image-1"

# --- 자동화 Cron 보호 토큰. /api/cron 호출 시 Authorization 헤더로 검증 ---
CRON_SECRET="change-me-cron-secret"

# 자동 발행 마스터 스위치. 대표 콘텐츠/파이프라인 검증 전까지 false 유지 (§8, §24)
AUTO_PUBLISH_ENABLED="false"
